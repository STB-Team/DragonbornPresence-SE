{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026",
      "displayName": "Visual Studio 2026 x64",
      "description": "Настройка проекта для Visual Studio 2026 и набора инструментов v145.",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/vs2026",
      "cacheVariables": {
        "BUILD_TESTING": "OFF",
        "DRAGONBORNPRESENCE_DEPLOY_DIR": "D:/Stb/[STB] Mod Organizer/mods/DragonbornPresence"
      }
    },
    {
      "name": "vs2026-tests",
      "displayName": "Visual Studio 2026 x64 tests",
      "description": "Отдельная конфигурация core, application и adapter unit tests.",
      "inherits": "vs2026",
      "binaryDir": "${sourceDir}/build/vs2026-tests",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "DRAGONBORNPRESENCE_DEPLOY_DIR": ""
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "vs2026",
      "configuration": "Release",
      "targets": [
        "DragonbornPresence"
      ]
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "vs2026",
      "configuration": "Debug",
      "targets": [
        "DragonbornPresence"
      ]
    },
    {
      "name": "tests",
      "displayName": "Unit tests",
      "configurePreset": "vs2026-tests",
      "configuration": "Release",
      "targets": [
        "DragonbornPresenceCoreTests",
        "DragonbornPresenceApplicationTests",
        "DragonbornPresenceAdapterTests"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "tests",
      "displayName": "Unit tests",
      "configurePreset": "vs2026-tests",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
